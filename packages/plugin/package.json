{
  "name": "vite-static-assets-plugin",
  "type": "module",
  "version": "3.0.0",
  "description": "Typesafe static assets with Vite",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc ",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit-extended": "vitest run --config vitest.unit-extended.config.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../README.md','README.md')\"",
    "postpack": "node -e \"try{require('node:fs').unlinkSync('README.md')}catch{}\"",
    "release": "bumpp package.json packages/*/package.json --commit --push --tag"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MartinBspheroid/vite-static-assets-plugin.git"
  },
  "files": [
    "dist",
    "client.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "keywords": [
    "vite",
    "plugin",
    "static"
  ],
  "author": "Martin Blasko",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.1",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^1.0.0",
    "bumpp": "^10.1.0",
    "git-cliff": "^2.8.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "dependencies": {
    "picomatch": "^4.0.4"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  }
}