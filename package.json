{
  "name": "@vite-static-assets-plugin/repo",
  "type": "module",
  "version": "3.0.0",
  "description": "Typesafe static assets with Vite",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc ",
    "test": "cd packages/plugin && vitest run",
    "test:watch": "cd packages/plugin && vitest",
    "test:coverage": "cd packages/plugin && vitest run --coverage",
    "pretest:harness": "cd packages/plugin && bun run build",
    "test:harness": "vitest run --config vitest.harness.config.ts",
    "prepare": "husky",
    "release": "bumpp package.json packages/*/package.json --commit --push --tag"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MartinBspheroid/vite-static-assets-plugin.git"
  },
  "files": [
    "dist",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "vite",
    "plugin",
    "static"
  ],
  "workspaces": [
    "test-apps/*",
    "packages/*"
  ],
  "author": "Martin Blasko",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vitest/coverage-v8": "^1.0.0",
    "bumpp": "^10.1.0",
    "cheerio": "^1.2.0",
    "execa": "^9.6.1",
    "get-port": "^7.2.0",
    "git-cliff": "^2.8.0",
    "husky": "^9.1.7",
    "strip-ansi": "^7.2.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "dependencies": {
    "picomatch": "^4.0.4"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  }
}
